{
  "name": "habit-hooks",
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "habit-hooks": "./dist/cli.js",
    "mapper": "./dist/mapper-cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/prompts/*.md",
    "src/prompts/*.njk",
    "!src/prompts/REVIEW.md",
    "src/skills"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p . && chmod +x dist/cli.js dist/mapper-cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "habit-hooks": "habit-hooks",
    "ci": "npm run lint && npm run test && npm run build && npm run habit-hooks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/nunjucks": "^3.2.6",
    "@types/picomatch": "^4.0.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "eslint": "^10.4.0",
    "fast-glob": "^3.3.3",
    "jiti": "^2.7.0",
    "jscpd": "4.2.4",
    "knip": "5.88.1",
    "nunjucks": "^3.2.4",
    "picomatch": "^4.0.4",
    "ts-morph": "^28.0.0",
    "typescript-eslint": "^8.60.0"
  }
}
