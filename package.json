    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "eslint": "^10.4.0",
    "fast-glob": "^3.3.3",
    "typescript-eslint": "^8.60.0"
  }
}
